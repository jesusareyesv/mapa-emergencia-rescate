# ── Backend que consume el BFF del admin ────────────────────────────────────
# El BFF (rutas app/api/*) llama al backend SOLO server-side. El navegador habla
# same-origin con el BFF, nunca directo al backend.
#
# `emergency` se resuelve en este orden (primer valor gana):
#   EMERGENCY_API_URL → INTERNAL_API_URL → NEXT_PUBLIC_API_URL
# En el cluster usa la red interna (p.ej. http://api.mapa.svc.cluster.local).
EMERGENCY_API_URL=
# Fallbacks (si no defines EMERGENCY_API_URL):
INTERNAL_API_URL=
NEXT_PUBLIC_API_URL=

# URL base de la API de suministros. NO se usa todavía (ApiId "supplies" está
# registrado pero ninguna ruta lo llama aún). Déjalo vacío hasta que llegue esa
# superficie.
SUPPLIES_API_URL=

# ── Sesión (cookie httpOnly del BFF) ────────────────────────────────────────
# Secure por defecto; ponlo en "false" SOLO en local (http) o el navegador
# descarta la cookie. En prod/staging (https) déjalo sin setear o "true".
COOKIE_SECURE=
# TTL de la cookie de sesión del BFF en segundos. Espeja JWT_TTL_SECONDS del
# backend. Default 43200 (12h).
SESSION_MAX_AGE_SECONDS=43200

# ── Runtime ─────────────────────────────────────────────────────────────────
# La imagen fija production. development relaja defaults para local.
NODE_ENV=

# ── Build (opcional, anti version-skew / CDN) ───────────────────────────────
# SHA del commit; estampa el build-id para que pods del mismo deploy sirvan los
# mismos /_next/static (evita ChunkLoadError en rolls multi-pod). Se pasa como
# build-arg en CI; en local cae a "dev".
APP_BUILD_SHA=
# Prefijo CDN para /_next/static (R2). Sin setear → la app sirve los assets.
NEXT_PUBLIC_ASSET_PREFIX=
