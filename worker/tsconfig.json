{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    // tsx ejecuta el worker como ESM (sin "type":"module" en package.json,
    // nodenext lo trataría como CJS y rompería import.meta en lib/*). bundler
    // resuelve sin exigir extensiones .js y respeta el alias "@/*", igual que
    // el tsconfig raíz que comparte el código de lib/.
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["**/*.ts"]
}
